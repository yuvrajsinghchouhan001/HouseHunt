<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2">
    <br>
    <h3>Create a new listing</h3>
    <form method="post" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
        <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input name="listing[title]" 
        placeholder="enter title" 
        type="text" 
        class="form-control" 
        required
        /> <!-- Here we have created key value pair. yaha par hamne ek object bana diya listing naam se aur uski key rakh di title-->
        <div class="valid-feedback">Title looks good!</div>
        <div class="invalid-feedback">Please enter a title!</div>
    </div>

        <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" 
        class="form-control" 
        required
        ></textarea>
        <div class="invalid-feedback">please enter the right discription </div>
        </div>

         <div class="mb-3">
        <label for="image" class="form-label">Upload Image </label>
         <input name="listing[image]" 
         type="file" 
         class="form-control" 
         required/>
         </div>
        
    <div class="row">
        <div class="mb-3 col-md-4">
        <label for="price" class="form-label">Price</label>
        <input name="listing[price]" 
        placeholder="enter price" 
        type="number"
        class="form-control"
        required
        />
        <div class="invalid-feedback">please enter a valid price</div>
        </div>

        <div class="mb-3 col-md-8">
        <label for="country" class="form-label">country</label>   
        <input name="listing[country]" 
        placeholder="enter country" 
        type="text"
        class="form-control" 
        required
        />
        <div class="invalid-feedback">please enter the right country name </div>
        </div>
    </div>
        
        <div class="mb-3">
        <label for="location" class="form-label">Location</label>    
        <input name="listing[location]" 
        placeholder="enter location" 
        type="text" 
        class="form-control"
        required
        />
        <div class="invalid-feedback">please enter the right location </div>
        </div>

        <button class="btn btn-dark add-btn mt-3">Add</button>
        <br>
    </form>
    </div>
</div>
