<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <h1  class="col-6 offset-3">SignUp on HouseHunt</h1>
    <div class="col-6 offset-3">
        <form action="/signup" method="POST" class = "needs-validation" novalidate>
             <div class="mb-3">
        <label for="username" class="form-label">Username</label>
        <input name="username" 
        id = "username"
        placeholder="Enter username" 
        type="text" 
        class="form-control" 
        required
        /> <!-- Here we have created key value pair. yaha par hamne ek object bana diya listing naam se aur uski key rakh di title-->
        <div class="valid-feedback">username looks good!</div>
        <div class="invalid-feedback">Please enter correct username</div>
    </div>

     <div class="mb-3">
        <label for="email" class="form-label">Email</label>
        <input name="email" 
        id = "email"
        placeholder="Enter email" 
        type="email" 
        class="form-control" 
        required
        /> <!-- Here we have created key value pair. yaha par hamne ek object bana diya listing naam se aur uski key rakh di title-->
        <div class="valid-feedback">email looks good!</div>
        <div class="invalid-feedback">Please enter correct email</div>
    </div>
    
    <div class="mb-3">
        <label for="password" class="form-label">Password</label>
        <input name="password" 
        id = "password"
        placeholder="Enter password" 
        type="password" 
        class="form-control" 
        required
        /> 
        <div class="valid-feedback">password looks good!</div>
        <div class="invalid-feedback">Please enter correct password</div>
    </div>
    
         <button class="btn btn-success">Signup</button>

        </form>
        </div>
    </div>